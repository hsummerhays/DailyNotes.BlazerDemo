@page "/tasks"
@using DailyNotes.Blazor.Components.UI
@using DailyNotes.Shared.Models
@inject HttpClient Http

<PageTitle>Tasks - DailyNotes</PageTitle>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1 style="font-size: 1.5rem; font-weight: 600;">Tasks</h1>
        <p style="color: var(--color-text-secondary); font-size: 0.875rem;">Manage your to-dos and project items</p>
    </div>
    <button class="btn btn-primary" @onclick="() => _isNewTaskModalOpen = true">+ New Task</button>
</div>

<div class="page-content">
    <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem;">
        @foreach (var filter in new[] { "Active", "Completed", "All" })
        {
            <button class="btn @(_currentFilter == filter ? "btn-secondary" : "btn-secondary")" 
                    style="padding: 0.3rem 0.6rem; font-size: 0.75rem; @(_currentFilter == filter ? "background: var(--color-bg-elevated); border-color: var(--color-primary);" : "")"
                    @onclick="() => SetFilter(filter)">
                @filter
            </button>
        }
    </div>

    @if (_isLoading)
    {
        <div style="display: flex; justify-content: center; padding: 3rem;">
            <div class="spinner"></div>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            @foreach (var task in _filteredTasks)
            {
                <div class="card" style="padding: 1rem; display: flex; align-items: center; gap: 1rem;">
                    <input type="checkbox" checked="@(task.Status == "completed")" 
                           @onclick="() => ToggleTaskStatus(task)"
                           class="darker-border-checkbox" style="width: 1.2rem; height: 1.2rem;" />
                    <div style="flex: 1;">
                        <div style="font-weight: 500; text-decoration: @(task.Status == "completed" ? "line-through" : "none"); color: @(task.Status == "completed" ? "var(--color-text-muted)" : "inherit")">
                            @task.Name
                        </div>
                        <div style="font-size: 0.8rem; color: var(--color-text-muted);">
                            @task.Status • @(task.DueDate?.ToString("MMM d") ?? "No due date")
                        </div>
                    </div>
                    @if (task.IsPinned)
                    {
                        <span style="font-size: 1.2rem;">📌</span>
                    }
                </div>
            }
        </div>
    }
</div>

<Modal Title="New Task" @bind-IsOpen="_isNewTaskModalOpen">
    <div style="display: flex; flex-direction: column; gap: 1rem;">
        <div>
            <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--color-text-secondary);">Task Name</label>
            <input type="text" placeholder="What needs to be done?" style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;" />
        </div>
        <div>
            <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem; color: var(--color-text-secondary);">Project (Optional)</label>
            <select style="width: 100%; background: var(--color-bg-elevated); color: inherit; border: 1px solid var(--color-border); padding: 0.75rem; border-radius: 8px;">
                <option value="">None</option>
            </select>
        </div>
    </div>
    <div style="display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 2rem;">
        <button class="btn btn-secondary" @onclick="() => _isNewTaskModalOpen = false">Cancel</button>
        <button class="btn btn-primary" @onclick="() => _isNewTaskModalOpen = false">Create Task</button>
    </div>
</Modal>

@code {
    private string _currentFilter = "Active";
    private bool _isLoading = true;
    private bool _isNewTaskModalOpen = false;
    private List<WorkTask> _tasks = new();
    private List<WorkTask> _filteredTasks = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            _tasks = await Http.GetFromJsonAsync<List<WorkTask>>("api/worktasks") ?? new();
            ApplyFilter();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SetFilter(string filter)
    {
        _currentFilter = filter;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (_currentFilter == "Active")
            _filteredTasks = _tasks.Where(t => t.Status != "completed").ToList();
        else if (_currentFilter == "Completed")
            _filteredTasks = _tasks.Where(t => t.Status == "completed").ToList();
        else
            _filteredTasks = _tasks.ToList();
    }

    private async Task ToggleTaskStatus(WorkTask task)
    {
        var newStatus = task.Status == "completed" ? "todo" : "completed";
        try
        {
            var response = await Http.PatchAsJsonAsync($"api/worktasks/{task.Id}/status", newStatus);
            if (response.IsSuccessStatusCode)
            {
                task.Status = newStatus;
                ApplyFilter();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
}
