@page "/notes"
@using DailyNotes.Shared
@inject HttpClient Http

<h3>Daily Notes</h3>

<input @bind="newNote" placeholder="Enter note" />
<button @onclick="AddNote">Add</button>

<ul>
    @foreach (var note in notes)
    {
        <li>
            @note.Text
            <button @onclick="() => Delete(note.Id)">x</button>
        </li>
    }
</ul>

@code {

    List<Note> notes = new();
    string newNote = "";

    protected override async Task OnInitializedAsync()
    {
        notes = await Http.GetFromJsonAsync<List<Note>>("api/notes") ?? new();
    }

    async Task AddNote()
    {
        if (string.IsNullOrWhiteSpace(newNote)) return;

        var note = new Note { Text = newNote };

        var response = await Http.PostAsJsonAsync("api/notes", note);
        
        if (response.IsSuccessStatusCode)
        {
            var createdNote = await response.Content.ReadFromJsonAsync<Note>();
            if (createdNote != null)
            {
                notes.Add(createdNote);
                newNote = "";
            }
        }
    }

    async Task Delete(int id)
    {
        var response = await Http.DeleteAsync($"api/notes/{id}");

        if (response.IsSuccessStatusCode)
        {
            notes.RemoveAll(n => n.Id == id);
        }
    }
}